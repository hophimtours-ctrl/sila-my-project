generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  GUEST
  OWNER
  ADMIN
}

enum DashboardRole {
  ADMIN
  MANAGER
  EDITOR
  VIEWER
}

enum HotelStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELED
}

enum RoomPaymentPolicy {
  CHARGE
  PREAUTH
}

enum CurrencyCode {
  ILS
  USD
  EUR
  GBP
}

enum PaymentGateway {
  STRIPE
  ISRAEL
}

enum BookingPaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  VOIDED
  REFUNDED
  FAILED
}

enum PaymentOperationType {
  CHARGE
  AUTHORIZE
  CAPTURE
  VOID
  REFUND
}

enum PaymentOperationStatus {
  SUCCEEDED
  FAILED
}

enum TripPurpose {
  BUSINESS
  WORK
}
enum BedType {
  DOUBLE
  TWIN
}

enum ProviderStatus {
  ACTIVE
  ERROR
  DISABLED
}

enum HotelDataSourceMode {
  MANUAL
  API
  HYBRID
}
enum HotelMarkupMode {
  PERCENTAGE
  AMOUNT
  MAX
}
enum SupplierType {
  HOTELBEDS
  MANUAL
  DIRECT
}
enum SupplierPaymentStatus {
  PAID
  PENDING
  PARTIAL
}

enum IntegrationLogLevel {
  INFO
  WARNING
  ERROR
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         Role      @default(GUEST)
  dashboardRole DashboardRole @default(VIEWER)
  customRoleId String?
  featurePermissions Json?
  blocked      Boolean   @default(false)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  hotels       Hotel[]
  bookings     Booking[]
  reviews      Review[]
  sessions     Session[]
  customRole   RoleDefinition? @relation(fields: [customRoleId], references: [id], onDelete: SetNull)
  loginHistory UserLoginHistory[]
  activityLogsAsActor UserActivityLog[] @relation("ActorActivityLogs")
  activityLogsAsTarget UserActivityLog[] @relation("TargetActivityLogs")
  favorites    Favorite[]
  hostingProperties HostingProperty[] @relation("HostingPropertyOwner")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}


model RoleDefinition {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  category    String
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
model Hotel {
  id          String       @id @default(cuid())
  ownerId     String
  providerId  String?
  externalHotelId String?
  name        String
  location    String
  city        String?
  country     String?
  contactEmail String?
  description String
  facilities  Json
  images      Json
  rating      Float?
  dataSourceMode HotelDataSourceMode @default(MANUAL)
  markupPercentage Float @default(0)
  markupAmount Float @default(0)
  markupMode HotelMarkupMode @default(PERCENTAGE)
  supplierType SupplierType @default(MANUAL)
  manualOverride Boolean @default(false)
  lastImportedAt DateTime?
  status      HotelStatus  @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  owner       User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  provider    HotelApiProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  roomTypes   RoomType[]
  bookings    Booking[]
  reviews     Review[]
  blockedDates BlockedDate[]
  favorites   Favorite[]
  deals       Deal[]

  @@unique([providerId, externalHotelId])
}

model RoomType {
  id                 String    @id @default(cuid())
  hotelId            String
  externalRoomId     String?
  name               String
  bedType            BedType   @default(DOUBLE)
  pricePerNight      Float
  maxGuests          Int
  inventory          Int       @default(1)
  availableInventory Int       @default(1)
  isAvailable        Boolean   @default(true)
  photos             Json?
  cancellationPolicy String
  paymentPolicy      RoomPaymentPolicy @default(CHARGE)
  currencyCode       CurrencyCode      @default(ILS)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  hotel              Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  bookings           Booking[]
  availabilityOverrides RoomAvailabilityOverride[]

  @@unique([hotelId, externalRoomId])
}

model HotelApiProvider {
  id                     String           @id @default(cuid())
  name                   String
  endpoint               String
  hotelsPath             String           @default("/hotels")
  apiKeyEncrypted        String
  apiSecretEncrypted     String?
  enabled                Boolean          @default(true)
  status                 ProviderStatus   @default(DISABLED)
  autoRefreshEnabled     Boolean          @default(false)
  refreshIntervalMinutes Int              @default(60)
  lastTestedAt           DateTime?
  lastRefreshedAt        DateTime?
  lastError              String?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  hotels                 Hotel[]
  logs                   HotelApiSyncLog[]
}

model HotelApiSyncLog {
  id         String              @id @default(cuid())
  providerId String
  level      IntegrationLogLevel @default(INFO)
  action     String
  message    String
  metadata   Json?
  createdAt  DateTime            @default(now())
  provider   HotelApiProvider    @relation(fields: [providerId], references: [id], onDelete: Cascade)
}

model UserLoginHistory {
  id          String   @id @default(cuid())
  userId       String?
  email        String
  success      Boolean
  message      String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model UserActivityLog {
  id            String   @id @default(cuid())
  actorUserId   String?
  targetUserId  String?
  scope         String
  action        String
  details       String
  metadata      Json?
  createdAt     DateTime @default(now())
  actorUser     User?    @relation("ActorActivityLogs", fields: [actorUserId], references: [id], onDelete: SetNull)
  targetUser    User?    @relation("TargetActivityLogs", fields: [targetUserId], references: [id], onDelete: SetNull)
}

model Booking {
  id                  String               @id @default(cuid())
  userId              String
  hotelId             String
  roomTypeId          String
  checkIn             DateTime
  checkOut            DateTime
  guests              Int
  guestNames          Json?
  tripPurpose         TripPurpose?
  specialRequests     String?
  totalPrice          Float
  netRate             Float                @default(0)
  sellRate            Float                @default(0)
  profitAmount        Float                @default(0)
  profitPercent       Float                @default(0)
  supplierType        SupplierType         @default(MANUAL)
  amountToPaySupplier Float                @default(0)
  supplierPaymentStatus SupplierPaymentStatus @default(PENDING)
  status              BookingStatus        @default(PENDING_PAYMENT)
  paymentPolicy       RoomPaymentPolicy    @default(CHARGE)
  currencyCode        CurrencyCode         @default(ILS)
  paymentGateway      PaymentGateway?
  paymentStatus       BookingPaymentStatus @default(PENDING)
  paymentReference    String?
  paymentToken        String?
  authorizedAmount    Float                @default(0)
  capturedAmount      Float                @default(0)
  refundedAmount      Float                @default(0)
  paymentErrorMessage String?
  paymentMetadata     Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotel               Hotel                @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomType            RoomType             @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  paymentOperations   BookingPaymentOperation[]
  settlement          Settlement?
}

model BookingPaymentOperation {
  id                String               @id @default(cuid())
  bookingId         String
  operationType     PaymentOperationType
  operationStatus   PaymentOperationStatus
  gateway           PaymentGateway
  currencyCode      CurrencyCode
  amount            Float
  providerReference String?
  gatewayReference  String?
  idempotencyKey    String?
  requestPayload    Json?
  responsePayload   Json?
  failureReason     String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  booking           Booking              @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}
model Settlement {
  id                  String                @id @default(cuid())
  bookingId           String                @unique
  supplierType        SupplierType          @default(MANUAL)
  netRate             Float                 @default(0)
  amountToPaySupplier Float                 @default(0)
  amountPaid          Float                 @default(0)
  paymentStatus       SupplierPaymentStatus @default(PENDING)
  paymentDate         DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  booking             Booking               @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  hotelId   String
  rating    Int
  comment   String
  images    Json?
  status    ReviewStatus @default(PENDING)
  verifiedStay Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
}

model HostingProperty {
  id           String   @id @default(cuid())
  ownerId      String?
  name         String
  description  String
  location     String
  city         String
  country      String
  contactEmail String
  images       Json
  facilities   Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  owner        User?    @relation("HostingPropertyOwner", fields: [ownerId], references: [id], onDelete: SetNull)
}

model Deal {
  id          String   @id @default(cuid())
  hotelId     String
  title       String
  description String
  dealPrice   Float
  validFrom   DateTime
  validTo     DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  hotel       Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
}

model RoomAvailabilityOverride {
  id            String   @id @default(cuid())
  roomTypeId    String
  date          DateTime
  isAvailable   Boolean  @default(true)
  priceOverride Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  roomType      RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@unique([roomTypeId, date])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  hotelId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([userId, hotelId])
}

model BlockedDate {
  id      String   @id @default(cuid())
  hotelId String
  date    DateTime
  hotel   Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, date])
}
